# Rename this from example.env to .env
VITE_DISCORD_CLIENT_ID=PASTE_OAUTH2_CLIENT_ID_HERE
# Local dev + Discord Activity both use /colyseus (Vite proxies locally; Discord maps it to your server)
VITE_COLYSEUS_URL=/colyseus
# Optional: override Vite proxy target (default http://localhost:2567)
# VITE_COLYSEUS_PROXY=http://localhost:2567
# Optional: backend host for patchUrlMappings (default discord-activity.up.railway.app)
# VITE_SERVER_HOST=discord-activity.up.railway.app

# Required Discord Developer Portal → Activities → URL Mappings:
#   (Do NOT put ".proxy" in the prefix — Discord rejects it)
#
#   PREFIX              TARGET
#   /                   your-client.vercel.app
#   /colyseus           discord-activity.up.railway.app
#   /youtube-nocookie   www.youtube-nocookie.com
