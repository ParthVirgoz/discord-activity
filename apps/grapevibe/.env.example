# Discord OAuth + JWT (server)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
JWT_SECRET=change-me-in-production

# Discord app id (client)
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# When embedded in Discord, map API/Socket.IO to this host (hostname:port, no scheme)
NEXT_PUBLIC_SERVER_HOST=localhost:3000

# Optional: direct backend URL for split deploy (e.g. https://grapevibe.onrender.com)
# NEXT_PUBLIC_SERVER_URL=

PORT=3000
