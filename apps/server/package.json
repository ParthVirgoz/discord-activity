{
  "private": true,
  "name": "server",
  "version": "1.0.0",
  "description": "Colyseus + Discord Embedded App SDK",
  "main": "build/index.js",
  "engines": {
    "node": ">= 16.13.0"
  },
  "scripts": {
    "start": "tsx watch src/index.ts",
    "start:prod": "node build/index.js",
    "loadtest": "tsx loadtest/example.ts --room watch_room --numClients 2",
    "build": "npm run clean && tsc",
    "clean": "rimraf build",
    "test": "mocha -r tsx test/UnoRoom_test.ts test/validation_test.ts --exit --timeout 15000",
    "test:smoke": "tsx test/smoke.integration.ts",
    "test:smoke:prod": "tsx test/smoke.integration.ts https://discord-activity.up.railway.app"
  },
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/colyseus/create-colyseus/issues"
  },
  "homepage": "https://github.com/colyseus/discord-embedded-app-sdk#readme",
  "devDependencies": {
    "@colyseus/loadtest": "^0.17.8",
    "@colyseus/testing": "^0.17.11",
    "@types/express": "^4.17.1",
    "@types/mocha": "^10.0.1",
    "mocha": "^10.2.0",
    "rimraf": "^5.0.0",
    "tsx": "^3.12.6",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@colyseus/auth": "^0.17.6",
    "@colyseus/monitor": "^0.17.7",
    "@colyseus/playground": "^0.17.10",
    "@colyseus/tools": "^0.17.18",
    "colyseus": "^0.17.8",
    "express": "^4.18.2",
    "uwebsockets-express": "^1.4.1"
  }
}
